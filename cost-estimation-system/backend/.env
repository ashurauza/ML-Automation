# Application Configuration
PORT=8000
ENV=development
DEBUG=True

# Database Configuration
DATABASE_URL=sqlite:///./cost_estimation.db
DATABASE_ECHO=True

# ML Model Configuration
MODEL_PATH=../ml_models/trained_models/
DEFAULT_CONFIDENCE_THRESHOLD=0.85

# Cost Parameters (Default values)
DEFAULT_MATERIAL_COST_MULTIPLIER=1.2
DEFAULT_MACHINING_RATE=50  # per hour
DEFAULT_LABOR_RATE=25     # per hour
DEFAULT_OVERHEAD_PERCENTAGE=15
DEFAULT_PROFIT_MARGIN=20

# File Upload Configuration
MAX_FILE_SIZE=50000000  # 50MB
ALLOWED_EXTENSIONS=pdf
UPLOAD_DIRECTORY=./uploads/

# Logging
LOG_LEVEL=INFO
